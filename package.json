{
  "name": "roadmapped",
  "version": "0.1.0",
  "description": "Project management as flat files in your repo — YAML tasks, a computed roadmap, driven by your AI agent through a CLI and a Claude skill. No database, no SaaS, no account.",
  "keywords": [
    "project-management",
    "ai-agents",
    "claude",
    "local-first",
    "flat-file",
    "yaml",
    "cli",
    "roadmap",
    "backlog",
    "open-source"
  ],
  "homepage": "https://roadmapped.work",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remicourtillon/Roadmapped.git"
  },
  "bugs": {
    "url": "https://github.com/remicourtillon/Roadmapped/issues"
  },
  "author": "Rémi Courtillon",
  "license": "MIT",
  "type": "module",
  "bin": {
    "roadmapped": "bin/roadmapped.mjs"
  },
  "files": [
    "bin",
    "scripts",
    "src",
    "skills",
    "index.html",
    "vite.config.ts",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "dev": "vite",
    "prepare": "git config core.hooksPath scripts/githooks || true",
    "build": "tsc -b && vite build",
    "build:demo": "tsc -b && vite build --config vite.demo.config.ts",
    "test": "vitest run",
    "validate": "node --experimental-strip-types scripts/task.mjs validate",
    "task": "node --experimental-strip-types scripts/task.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dagrejs/dagre": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "amaro": "^1.1.10",
    "js-yaml": "^4.1.0",
    "marked": "18.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.3.0",
    "trinil-react": "^1.3.9",
    "vite": "^5.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
